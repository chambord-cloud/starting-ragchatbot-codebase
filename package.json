{
  "name": "rag-chatbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "RAG Chatbot - Course Materials Assistant",
  "scripts": {
    "format": "prettier --write \"frontend/**/*.{html,css,js}\"",
    "format:check": "prettier --check \"frontend/**/*.{html,css,js}\"",
    "lint": "eslint \"frontend/**/*.js\"",
    "lint:fix": "eslint --fix \"frontend/**/*.js\"",
    "check": "npm run format:check && npm run lint",
    "fix": "npm run format && npm run lint:fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  }
}
